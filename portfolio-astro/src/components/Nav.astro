---
const links = [
  { href: '#about',    label: 'About' },
  { href: '#skills',   label: 'Skills' },
  { href: '#homelab',  label: 'Homelab' },
  { href: '#projects', label: 'Projects' },
  { href: '#contact',  label: 'Contact' },
];
---

<nav
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo / name -->
    <a href="#" class="font-mono text-sm text-slate-400 hover:text-indigo-400 transition-colors">
      <span class="text-indigo-400">~/</span>fbarnola
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="text-sm text-slate-400 hover:text-white transition-colors relative group"
          >
            {label}
            <span class="absolute -bottom-0.5 left-0 w-0 h-px bg-indigo-400 transition-all duration-300 group-hover:w-full" />
          </a>
        </li>
      ))}
    </ul>

    <!-- CV button -->
    <a
      href="/assets/francesc_barnola_cv.pdf"
      target="_blank"
      class="hidden md:inline-flex items-center gap-2 px-4 py-1.5 rounded-lg text-sm font-medium border border-indigo-500/40 text-indigo-300 hover:bg-indigo-500/10 hover:border-indigo-400 transition-all duration-200"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M12 15V3m0 12-4-4m4 4 4-4M2 17l.621 2.485A2 2 0 0 0 4.561 21h14.878a2 2 0 0 0 1.94-1.515L22 17"/>
      </svg>
      Resume
    </a>

    <!-- Mobile hamburger -->
    <button id="menu-btn" class="md:hidden text-slate-400 hover:text-white transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-white/5 bg-[#07080f]/95 backdrop-blur-xl px-6 py-4"
  >
    <ul class="flex flex-col gap-4">
      {links.map(({ href, label }) => (
        <li>
          <a href={href} class="text-slate-300 hover:text-white transition-colors text-sm mobile-link">
            {label}
          </a>
        </li>
      ))}
      <li class="pt-2 border-t border-white/5">
        <a
          href="/assets/francesc_barnola_cv.pdf"
          target="_blank"
          class="text-indigo-400 text-sm hover:text-indigo-300"
        >
          Download Resume ↓
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  // Nav scroll effect
  const nav = document.getElementById('nav');
  const handler = () => {
    nav?.classList.toggle(
      'bg-[#07080f]/80',
      window.scrollY > 20
    );
    nav?.classList.toggle('backdrop-blur-xl', window.scrollY > 20);
    nav?.classList.toggle('border-b', window.scrollY > 20);
    nav?.classList.toggle('border-white/5', window.scrollY > 20);
  };
  window.addEventListener('scroll', handler, { passive: true });
  handler();

  // Mobile menu
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>
