---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden px-6 pt-16">
  <!-- Background glows -->
  <div class="glow-blob w-[600px] h-[600px] bg-indigo-600/10 -top-32 -left-32 animate-pulse-slow" style="position:absolute;"></div>
  <div class="glow-blob w-[400px] h-[400px] bg-cyan-500/8 bottom-0 right-0 animate-pulse-slow" style="position:absolute; animation-delay: 1.5s;"></div>

  <div class="max-w-6xl mx-auto w-full grid md:grid-cols-2 gap-12 items-center">
    <!-- Text -->
    <div class="order-2 md:order-1 animate-fade-up" style="animation-delay: 0.1s;">
      <!-- Status badge -->
      <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full bg-green-500/10 border border-green-500/20 text-green-400 text-xs font-mono">
        <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
        Available for opportunities
      </div>

      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold mb-4 leading-tight tracking-tight">
        Francesc<br/>
        <span class="gradient-text">Barnola</span>
      </h1>

      <p class="text-lg md:text-xl text-slate-400 font-light mb-2">
        DevOps Engineer &amp; Cloud Architect
      </p>
      <p class="text-slate-500 text-sm mb-8 font-mono">
        AWS Certified Solutions Architect • Associate
      </p>

      <p class="text-slate-300 leading-relaxed mb-10 max-w-lg">
        I build and automate cloud infrastructure at scale — from bare-metal Kubernetes clusters to CI/CD pipelines,
        observability stacks, and secure DevSecOps workflows. Currently at
        <a href="https://fundcraft.com" target="_blank" class="text-indigo-400 hover:text-indigo-300 transition-colors">Fundcraft</a>.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4">
        <a
          href="#projects"
          class="px-6 py-3 bg-indigo-600 hover:bg-indigo-500 text-white rounded-xl font-medium transition-all duration-200 shadow-lg shadow-indigo-900/30 hover:shadow-indigo-900/50 hover:-translate-y-0.5"
        >
          View Work
        </a>
        <a
          href="#contact"
          class="px-6 py-3 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 text-slate-300 hover:text-white rounded-xl font-medium transition-all duration-200"
        >
          Get in Touch
        </a>
      </div>

      <!-- Quick links -->
      <div class="flex items-center gap-5 mt-10">
        <a href="https://github.com/barnolacesc" target="_blank" rel="noopener" class="text-slate-500 hover:text-white transition-colors" aria-label="GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
        <a href="https://linkedin.com/in/fbarnola" target="_blank" rel="noopener" class="text-slate-500 hover:text-white transition-colors" aria-label="LinkedIn">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <span class="text-slate-700">|</span>
        <span class="text-slate-600 text-xs font-mono">Barcelona, Spain · Remote</span>
      </div>
    </div>

    <!-- Profile image -->
    <div class="order-1 md:order-2 flex justify-center animate-fade-in" style="animation-delay: 0.3s;">
      <div class="relative">
        <!-- Glow ring -->
        <div class="absolute inset-0 rounded-full bg-gradient-to-br from-indigo-500/30 to-cyan-500/20 blur-2xl scale-110"></div>
        <!-- Ring border -->
        <div class="relative w-56 h-56 md:w-72 md:h-72 rounded-full p-0.5 bg-gradient-to-br from-indigo-500/60 to-cyan-500/40">
          <div class="w-full h-full rounded-full overflow-hidden bg-slate-900">
            <img
              src="/profile.jpg"
              alt="Francesc Barnola"
              class="w-full h-full object-cover"
            />
          </div>
        </div>
        <!-- AWS badge floating -->
        <div class="absolute -bottom-2 -right-2 md:bottom-4 md:-right-8 flex items-center gap-2 bg-[#0d0e1a] border border-amber-500/30 rounded-xl px-3 py-2 shadow-xl">
          <span class="text-amber-400 text-lg">☁</span>
          <div>
            <div class="text-amber-300 text-xs font-bold leading-tight">AWS Certified</div>
            <div class="text-slate-500 text-[10px] font-mono">SAA-C03</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 text-slate-600 text-xs font-mono animate-bounce">
    <span>scroll</span>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>
