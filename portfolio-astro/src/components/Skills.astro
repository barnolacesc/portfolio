---
const skills = [
  {
    cat: 'AI / LLM Engineering',
    items: ['Anthropic API', 'Claude Code', 'Cursor', 'Gemini CLI', 'Bedrock', 'Vertex AI', 'Kendra', 'Ollama', 'n8n', 'RAG', 'Agent orchestration'],
  },
  {
    cat: 'Orchestration',
    items: ['Kubernetes', 'K3s', 'Docker', 'Helm', 'Traefik', 'cert-manager', 'Sealed Secrets'],
  },
  {
    cat: 'IaC & Automation',
    items: ['Terraform', 'Ansible', 'Helm Charts', 'Kustomize', 'n8n'],
  },
  {
    cat: 'Cloud',
    items: ['AWS (SAA)', 'GCP', 'Azure', 'Cloudflare', 'Proxmox VE', 'Hetzner'],
  },
  {
    cat: 'Observability',
    items: ['Prometheus', 'Grafana', 'Loki', 'InfluxDB', 'Alertmanager', 'Fluent Bit', 'OpenObserve'],
  },
  {
    cat: 'CI/CD',
    items: ['GitHub Actions', 'GitLab CI', 'Jenkins', 'Self-hosted Runners', 'ArgoCD', 'pre-commit'],
  },
  {
    cat: 'Languages',
    items: ['Python', 'Bash', 'Go', 'TypeScript', 'Lua', 'SQL', 'HCL'],
  },
  {
    cat: 'Security',
    items: ['Trivy', 'Falco', 'SonarQube', 'OPA', 'JWT / RS256', 'Sealed Secrets', 'TLS automation'],
  },
  {
    cat: 'Storage & Network',
    items: ['TrueNAS', 'NFS / SMB / iSCSI', 'Pi-hole', 'k8s_gateway', 'WireGuard'],
  },
];
---

<section id="skills" class="section-wrap">

  <div class="reveal">
    <div class="section-eyebrow">
      <span class="section-num">03 / Skills</span>
    </div>
    <h2 class="section-title">Technical<br/>inventory.</h2>
  </div>

  <p class="reveal font-mono" data-delay="0.1s" style="font-size: 0.88rem; color: var(--fg); background: var(--bg-2); padding: 18px 24px; border-left: 2px solid var(--amber); margin-bottom: 48px; max-width: 600px; line-height: 1.8; letter-spacing: -0.01em;">
    Every line below is something I've actually run <span style="color: var(--amber); font-weight: 500;">in anger</span> —
    either in production at work or in the homelab <span style="font-style: italic;">at 2am</span>.
  </p>

  <div class="reveal" data-delay="0.15s">
    {skills.map((row) => (
      <div class="skill-row">
        <div class="skill-cat">{row.cat}</div>
        <div class="skill-list">
          {row.items.map((item, i) => (
            <span>{item}</span>
          ))}
        </div>
      </div>
    ))}
  </div>

</section>
